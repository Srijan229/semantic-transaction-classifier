generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TransactionCategory {
  categoryCode          String        @id
  categoryName          String
  categoryDescription   String
  predictedTransactions Transaction[] @relation("PredictedCategory")
  finalTransactions     Transaction[] @relation("FinalCategory")
}

model Transaction {
  id                    String               @id @default(uuid())
  transactionDate       DateTime
  description           String
  amount                Decimal
  accountNumber         String
  cusip                 String?

  predictedCategoryCode String?
  predictedCategory     TransactionCategory? @relation("PredictedCategory", fields: [predictedCategoryCode], references: [categoryCode])

  confidenceScore       Float?
  classificationMethod  String?
  matchedKeyword        String?
  reasoning             String?
  finalCategoryCode     String?
  finalCategory         TransactionCategory? @relation("FinalCategory", fields: [finalCategoryCode], references: [categoryCode])
  reviewStatus          String               @default("PENDING")
  createdAt             DateTime             @default(now())
}
